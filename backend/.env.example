# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/billbybillu"

# Auth
JWT_SECRET="change-this-to-a-random-string-in-production"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Server
PORT=5000
NODE_ENV=development

# Razorpay (Platform-level keys for subscription payments)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# Encryption (for user Razorpay secrets in DB; falls back to JWT_SECRET)
ENCRYPTION_KEY="change-this-to-a-different-random-string"

# Frontend URL (for payment link callback)
FRONTEND_URL=http://localhost:5173
