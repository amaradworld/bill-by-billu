# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/billbybillu"

# Auth
JWT_SECRET="change-this-to-a-random-string-in-production"

# Google Sign-In: comma-separated list of accepted OAuth client IDs
# (Web client ID + Android client ID). Used to verify Google ID tokens.
GOOGLE_CLIENT_IDS=""

# Platform owner email (admin access for blog/admin routes)
PLATFORM_OWNER_EMAIL="owner@example.com"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Server
PORT=5000
NODE_ENV=development

# Razorpay (Platform-level keys for subscription payments)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# Encryption (for user Razorpay secrets in DB; falls back to JWT_SECRET)
ENCRYPTION_KEY="change-this-to-a-different-random-string"

# Frontend URL (for payment link callback)
FRONTEND_URL=http://localhost:5173

# Backend URL (for WhatsApp webhook)
BACKEND_URL=http://localhost:5000

# WhatsApp Cloud API (for invoice bot)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
